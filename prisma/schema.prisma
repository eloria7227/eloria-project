generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  PROCESSING
  READY
  SHIPPING
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Product {
  id             String      @id @default(cuid())
  title          String
  slug           String      @unique
  description    String
  story          String?
  image          String

  goldWeight     Float
  goldType       String
  stoneType      String?

  makingPercent  Float
  profitPercent  Float
  taxPercent     Float
  designFee      Int

  active         Boolean     @default(true)

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  orderItems     OrderItem[]
}

model Customer {
  id         String    @id @default(cuid())

  fullName   String
  phone      String    @unique
  address    String

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  orders      Order[]
}

model Order {
  id               String         @id @default(cuid())

  orderCode        String         @unique

  customerId       String
  customer         Customer       @relation(fields: [customerId], references: [id])

  goldPrice        Int
  totalPrice       Int

  paymentStatus    PaymentStatus  @default(PENDING)
  orderStatus      OrderStatus    @default(PENDING)

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  items            OrderItem[]
}

model OrderItem {
  id            String    @id @default(cuid())

  orderId       String
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId     String
  product       Product   @relation(fields: [productId], references: [id])

  quantity      Int

  title         String

  goldWeight    Float
  goldType      String
  stoneType     String?

  unitPrice     Int
  totalPrice    Int

  createdAt     DateTime  @default(now())
}

model GoldPriceHistory {
  id         String    @id @default(cuid())

  price      Int

  createdAt  DateTime  @default(now())
}